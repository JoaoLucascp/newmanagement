{
    "name": "glpi-project/newmanagement",
    "description": "Plugin GLPI para gerenciamento de empresas, IPBX, chatbots e linhas fixas",
    "type": "glpi-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "JoaoLucascp",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "GlpiPlugin\\Newmanagement\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlpiPlugin\\Newmanagement\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
