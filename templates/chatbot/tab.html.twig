{#
  templates/chatbot/tab.html.twig
  Aba principal do Chatbot dentro da ficha de Empresa.
#}
<div class="nm-chatbot-tab nm-chatbot-page"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-companies-id="{{ companies_id }}"
     data-can-delete="{{ can_delete ? '1' : '0' }}">

  <div id="nm-chatbot-form-wrapper" class="nm-chatbot-form-panel">
    <input type="hidden" id="nm-chatbot-csrf" name="_glpi_csrf_token" value="{{ csrf|e }}">
    <input type="hidden" id="nm-chatbot-action" value="{{ form_action }}">
    <input type="hidden" id="nm-chatbot-id" value="{{ chatbot_id }}">
    <input type="hidden" id="nm-chatbot-companies-id" value="{{ companies_id }}">

    <div class="nm-section-heading">
      <div class="nm-section-title">
        <i class="ti ti-robot" aria-hidden="true"></i>
        <span>{{ __('Chatbot', 'newmanagement') }}</span>
      </div>
      {% if chatbot_id > 0 %}
        <span class="badge bg-secondary-lt">ID {{ chatbot_id }}</span>
      {% endif %}
    </div>

    <div class="nm-chatbot-grid">
      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-model">{{ __('Modelo do Chatbot', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-model"
               value="{{ f.model|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-registration_id">{{ __('ID de Cadastro', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-registration_id"
               value="{{ f.chatbot_registration_id|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-activation_date">{{ __('Data de Ativação', 'newmanagement') }}</label>
        <input type="date" id="nm-chatbot-activation_date"
               value="{{ f.activation_date|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-whatsapp">{{ __('Número WhatsApp', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-whatsapp"
               value="{{ f.whatsapp_number|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: 5511999999999"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-access_link">{{ __('Link de Acesso', 'newmanagement') }}</label>
        <input type="url" id="nm-chatbot-access_link"
               value="{{ f.access_link|e('html_attr') }}"
               class="form-control"
               placeholder="https://"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-plan">{{ __('Plano Contratado', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-plan"
               value="{{ f.plan|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-users_count">{{ __('Qtd. Usuários', 'newmanagement') }}</label>
        <input type="number" id="nm-chatbot-users_count"
               value="{{ f.users_count|e('html_attr') }}"
               class="form-control" min="0"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-supervisors_count">{{ __('Qtd. Supervisores', 'newmanagement') }}</label>
        <input type="number" id="nm-chatbot-supervisors_count"
               value="{{ f.supervisors_count|e('html_attr') }}"
               class="form-control" min="0"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-admins_count">{{ __('Qtd. Administradores', 'newmanagement') }}</label>
        <input type="number" id="nm-chatbot-admins_count"
               value="{{ f.admins_count|e('html_attr') }}"
               class="form-control" min="0"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-social_networks">{{ __('Redes Sociais Ativas', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-social_networks"
               value="{{ f.social_networks|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: WhatsApp, Instagram, Telegram"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-chatbot-grid-heading">
        <i class="ti ti-key" aria-hidden="true"></i>
        <span>{{ __('Credenciais de Administrador', 'newmanagement') }}</span>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-admin_login">{{ __('Login Admin', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-admin_login"
               value="{{ f.admin_login|e('html_attr') }}"
               class="form-control" autocomplete="off"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-admin_password">
          {{ chatbot_id > 0 ? __('Nova Senha Admin', 'newmanagement') : __('Senha Admin', 'newmanagement') }}
        </label>
        <div class="input-group nm-password-group">
          <input type="password" id="nm-chatbot-admin_password"
                 class="form-control" autocomplete="new-password"
                 value=""
                 placeholder="{{ f.has_admin_password ? '******' : '' }}"
                 {{ not can_write ? 'readonly disabled' }}>
          {% if can_write %}
            <button type="button" class="btn btn-icon nm-btn-eye"
                    data-target="nm-chatbot-admin_password"
                    title="{{ __('Mostrar ou ocultar senha', 'newmanagement') }}">
              <i class="ti ti-eye"></i>
            </button>
          {% endif %}
        </div>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-superadmin_login">{{ __('Login Super-Admin', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-superadmin_login"
               value="{{ f.superadmin_login|e('html_attr') }}"
               class="form-control" autocomplete="off"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-3">
        <label class="form-label" for="nm-chatbot-superadmin_password">
          {{ chatbot_id > 0 ? __('Nova Senha Super-Admin', 'newmanagement') : __('Senha Super-Admin', 'newmanagement') }}
        </label>
        <div class="input-group nm-password-group">
          <input type="password" id="nm-chatbot-superadmin_password"
                 class="form-control" autocomplete="new-password"
                 value=""
                 placeholder="{{ f.has_superadmin_password ? '******' : '' }}"
                 {{ not can_write ? 'readonly disabled' }}>
          {% if can_write %}
            <button type="button" class="btn btn-icon nm-btn-eye"
                    data-target="nm-chatbot-superadmin_password"
                    title="{{ __('Mostrar ou ocultar senha', 'newmanagement') }}">
              <i class="ti ti-eye"></i>
            </button>
          {% endif %}
        </div>
      </div>

      <div class="nm-chatbot-grid-heading">
        <i class="ti ti-user-check" aria-hidden="true"></i>
        <span>{{ __('Responsável pelo Chatbot', 'newmanagement') }}</span>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-manager_name">{{ __('Nome do Responsável', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-manager_name"
               value="{{ f.manager_name|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-manager_contact">{{ __('Contato do Responsável', 'newmanagement') }}</label>
        <input type="text" id="nm-chatbot-manager_contact"
               value="{{ f.manager_contact|e('html_attr') }}"
               class="form-control"
               placeholder="(00) 00000-0000"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-4">
        <label class="form-label" for="nm-chatbot-manager_email">{{ __('E-mail do Responsável', 'newmanagement') }}</label>
        <input type="email" id="nm-chatbot-manager_email"
               value="{{ f.manager_email|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </div>

      <div class="nm-field nm-chatbot-col-full">
        <label class="form-label" for="nm-chatbot-comment">{{ __('Comentário', 'newmanagement') }}</label>
        <textarea id="nm-chatbot-comment" class="form-control" rows="2"
                  {{ not can_write ? 'readonly disabled' }}>{{ f.comment|e }}</textarea>
      </div>
    </div>
  </div>

  <div class="nm-tabs-wrapper nm-chatbot-tabs nm-chatbot-related">
    <div class="nm-tab-bar" role="tablist" aria-label="{{ __('Recursos do Chatbot', 'newmanagement') }}">
      <button type="button"
              class="nm-tab active"
              role="tab"
              aria-selected="true"
              aria-controls="nm-panel-mc"
              id="nm-tab-mc"
              data-panel="nm-panel-mc">
        <i class="ti ti-send" aria-hidden="true"></i>
        {{ __('Comunicação em Massa', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-mc">{{ mass_comm|length }}</span>
      </button>

      <button type="button"
              class="nm-tab"
              role="tab"
              aria-selected="false"
              aria-controls="nm-panel-wa"
              id="nm-tab-wa"
              data-panel="nm-panel-wa">
        <i class="ti ti-ban" aria-hidden="true"></i>
        {{ __('Números Restritos pela Meta', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-wa">{{ wa_restrictions|length }}</span>
      </button>

      <button type="button"
              class="nm-tab"
              role="tab"
              aria-selected="false"
              aria-controls="nm-panel-cu"
              id="nm-tab-cu"
              data-panel="nm-panel-cu">
        <i class="ti ti-users" aria-hidden="true"></i>
        {{ __('Usuários Cadastrados no Chatbot', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-cu">{{ users|length }}</span>
      </button>
    </div>

    <div class="nm-tab-panel active" id="nm-panel-mc" role="tabpanel" aria-labelledby="nm-tab-mc">
      {% include '@newmanagement/chatbot/partials/mass_comm.html.twig' %}
    </div>

    <div class="nm-tab-panel" id="nm-panel-wa" role="tabpanel" aria-labelledby="nm-tab-wa" hidden>
      {% include '@newmanagement/chatbot/partials/wa_restrictions.html.twig' %}
    </div>

    <div class="nm-tab-panel" id="nm-panel-cu" role="tabpanel" aria-labelledby="nm-tab-cu" hidden>
      {% include '@newmanagement/chatbot/partials/users.html.twig' %}
    </div>
  </div>

  {% if can_write %}
    <div class="nm-chatbot-savebar">
      <button type="button" id="nm-chatbot-save"
              class="btn btn-primary"
              data-action-url="{{ action_url|e('html_attr') }}">
        <i class="ti ti-device-floppy"></i>
        {{ __('Salvar Chatbot', 'newmanagement') }}
      </button>
    </div>
  {% endif %}
</div>
