{#
  Tabela de Números Restritos pela Meta.
#}
{% set wa_total = wa_restrictions|length %}

<div id="nm-wa-section"
     class="nm-related-section nm-chatbot-table-section"
     data-section="wa_restrictions"
     data-chatbot-id="{{ chatbot_id }}"
     data-companies-id="{{ companies_id }}"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-total="{{ wa_total }}">

  <div class="nm-related-toolbar">
    <div class="nm-related-heading">
      <div class="nm-related-title">
        <i class="ti ti-ban" aria-hidden="true"></i>
        <span>{{ __('Números Restritos pela Meta', 'newmanagement') }}</span>
      </div>
      <span class="nm-related-meta"><span class="nm-count-wa">{{ wa_total }}</span> {{ __('restrições', 'newmanagement') }}</span>
    </div>
    {% if can_write %}
      <button type="button" id="nm-wa-add-btn"
              class="btn btn-sm btn-outline-primary"
              data-chatbot-id="{{ chatbot_id }}"
              data-companies-id="{{ companies_id }}">
        <i class="ti ti-plus"></i> {{ __('Adicionar', 'newmanagement') }}
      </button>
    {% endif %}
  </div>

  <div class="table-responsive nm-table-wrap">
    <table class="table table-vcenter table-hover nm-data-table nm-chatbot-table nm-wa-table" id="nm-wa-table">
      <colgroup>
        <col class="nm-col-wa-number">
        <col class="nm-col-wa-date">
        <col class="nm-col-wa-time">
        <col class="nm-col-wa-date">
        <col class="nm-col-actions">
      </colgroup>
      <thead>
        <tr>
          <th>{{ __('Número WhatsApp', 'newmanagement') }}</th>
          <th>{{ __('Data Início', 'newmanagement') }}</th>
          <th>{{ __('Tempo de Restrição', 'newmanagement') }}</th>
          <th>{{ __('Data Fim', 'newmanagement') }}</th>
          <th class="text-end"></th>
        </tr>
      </thead>

      <tbody id="nm-wa-tbody">
        {% for row in wa_restrictions %}
          <tr class="tab_bg_1 nm-wa-saved-row" id="nm-wa-row-{{ row.id }}">
            <td>{{ row.whatsapp_number|default('')|e }}</td>
            <td>{{ row.restriction_date|default('')|e }}</td>
            <td>{{ row.restriction_time|default('')|e }}</td>
            <td>{{ row.end_date|default('')|e }}</td>
            <td class="text-end">
              {% if can_delete %}
                <button type="button"
                        class="btn btn-sm btn-icon nm-chatbot-del"
                        data-action="delete_wa_restriction"
                        data-id="{{ row.id }}"
                        data-row="nm-wa-row-{{ row.id }}"
                        data-companies-id="{{ companies_id }}"
                        data-url="{{ action_url|e('html_attr') }}"
                        data-confirm="{{ __('Remover número restrito?', 'newmanagement') }}"
                        title="{{ __('Remover', 'newmanagement') }}">
                  <i class="ti ti-trash text-danger"></i>
                </button>
              {% endif %}
            </td>
          </tr>
        {% endfor %}

        {% if wa_restrictions is empty %}
          <tr id="nm-wa-empty">
            <td colspan="5" class="text-center text-muted py-3">
              {{ __('Nenhum número restrito cadastrado.', 'newmanagement') }}
            </td>
          </tr>
        {% endif %}

        {% if can_write %}
          <tr class="nm-wa-input-template" id="nm-wa-add-row" hidden style="display:none">
            <td><input type="text" class="nm-wa-whatsapp_number form-control form-control-sm" form="_none" autocomplete="off" placeholder="5511..."></td>
            <td><input type="date" class="nm-wa-restriction_date form-control form-control-sm" form="_none"></td>
            <td><input type="text" class="nm-wa-restriction_time form-control form-control-sm" form="_none" autocomplete="off" placeholder="Ex: 24h, 7 dias"></td>
            <td><input type="date" class="nm-wa-end_date form-control form-control-sm" form="_none"></td>
            <td class="text-end">
              <button type="button" class="btn btn-sm btn-icon nm-row-del-btn" title="{{ __('Descartar linha', 'newmanagement') }}">
                <i class="ti ti-trash text-danger"></i>
              </button>
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
