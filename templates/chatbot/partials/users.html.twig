{#
  Tabela de Usuários Cadastrados no Chatbot.
#}
{% set cu_total = users|length %}

<div id="nm-cu-section"
     class="nm-related-section nm-chatbot-table-section"
     data-section="users"
     data-chatbot-id="{{ chatbot_id }}"
     data-companies-id="{{ companies_id }}"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-total="{{ cu_total }}">

  <div class="nm-related-toolbar">
    <div class="nm-related-heading">
      <div class="nm-related-title">
        <i class="ti ti-users" aria-hidden="true"></i>
        <span>{{ __('Usuários Cadastrados no Chatbot', 'newmanagement') }}</span>
      </div>
      <span class="nm-related-meta"><span class="nm-count-cu">{{ cu_total }}</span> {{ __('usuários', 'newmanagement') }}</span>
    </div>
    {% if can_write %}
      <button type="button" id="nm-cu-add-btn"
              class="btn btn-sm btn-outline-primary"
              data-chatbot-id="{{ chatbot_id }}"
              data-companies-id="{{ companies_id }}">
        <i class="ti ti-plus"></i> {{ __('Adicionar', 'newmanagement') }}
      </button>
    {% endif %}
  </div>

  <div class="table-responsive nm-table-wrap">
    <table class="table table-vcenter table-hover nm-data-table nm-chatbot-table nm-cu-table" id="nm-cu-table">
      <colgroup>
        <col class="nm-col-cu-name">
        <col class="nm-col-cu-login">
        <col class="nm-col-cu-password">
        <col class="nm-col-cu-email">
        <col class="nm-col-cu-type">
        <col class="nm-col-actions">
      </colgroup>
      <thead>
        <tr>
          <th>{{ __('Nome', 'newmanagement') }}</th>
          <th>{{ __('Login', 'newmanagement') }}</th>
          <th>{{ __('Senha', 'newmanagement') }}</th>
          <th>{{ __('E-mail', 'newmanagement') }}</th>
          <th>{{ __('Tipo', 'newmanagement') }}</th>
          <th class="text-end"></th>
        </tr>
      </thead>

      <tbody id="nm-cu-tbody">
        {% for row in users %}
          <tr class="tab_bg_1 nm-cu-saved-row" id="nm-cu-row-{{ row.id }}">
            <td>{{ row.user_name|default('')|e }}</td>
            <td>{{ row.login|default('')|e }}</td>
            <td>******</td>
            <td>{{ row.email|default('')|e }}</td>
            <td>{{ row.user_type|default('')|e }}</td>
            <td class="text-end">
              {% if can_delete %}
                <button type="button"
                        class="btn btn-sm btn-icon nm-chatbot-del"
                        data-action="delete_chatbot_user"
                        data-id="{{ row.id }}"
                        data-row="nm-cu-row-{{ row.id }}"
                        data-companies-id="{{ companies_id }}"
                        data-url="{{ action_url|e('html_attr') }}"
                        data-confirm="{{ __('Remover usuário?', 'newmanagement') }}"
                        title="{{ __('Remover', 'newmanagement') }}">
                  <i class="ti ti-trash text-danger"></i>
                </button>
              {% endif %}
            </td>
          </tr>
        {% endfor %}

        {% if users is empty %}
          <tr id="nm-cu-empty">
            <td colspan="6" class="text-center text-muted py-3">
              {{ __('Nenhum usuário cadastrado.', 'newmanagement') }}
            </td>
          </tr>
        {% endif %}

        {% if can_write %}
          <tr class="nm-cu-input-template" id="nm-cu-add-row" hidden style="display:none">
            <td><input type="text" class="nm-cu-user_name form-control form-control-sm" form="_none" autocomplete="off" placeholder="{{ __('Nome', 'newmanagement') }}"></td>
            <td><input type="text" class="nm-cu-login form-control form-control-sm" form="_none" autocomplete="off" placeholder="{{ __('Login', 'newmanagement') }}"></td>
            <td><input type="password" class="nm-cu-password form-control form-control-sm" form="_none" autocomplete="new-password" placeholder="{{ __('Senha', 'newmanagement') }}"></td>
            <td><input type="email" class="nm-cu-email form-control form-control-sm" form="_none" autocomplete="off" placeholder="email@"></td>
            <td>
              <select class="nm-cu-user_type form-select form-select-sm" form="_none">
                <option value="usuario">{{ __('Usuário', 'newmanagement') }}</option>
                <option value="supervisor">{{ __('Supervisor', 'newmanagement') }}</option>
                <option value="administrador">{{ __('Administrador', 'newmanagement') }}</option>
              </select>
            </td>
            <td class="text-end">
              <button type="button" class="btn btn-sm btn-icon nm-row-del-btn" title="{{ __('Descartar linha', 'newmanagement') }}">
                <i class="ti ti-trash text-danger"></i>
              </button>
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
