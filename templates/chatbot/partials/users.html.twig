{#
  templates/chatbot/partials/users.html.twig
  Tabela de Usuários Cadastrados no Chatbot.
  Herda do contexto pai: chatbot_id, companies_id, csrf, action_url, can_write, can_delete, users
#}
<table class="tab_cadre_fixehov" id="nm-cu-table">
  <thead>
    <tr class="headerRow noHover">
      <th>{{ 'Nome'|trans({}, 'newmanagement') }}</th>
      <th>{{ 'Login'|trans({}, 'newmanagement') }}</th>
      <th>{{ 'Senha'|trans({}, 'newmanagement') }}</th>
      <th>{{ 'E-mail'|trans({}, 'newmanagement') }}</th>
      <th>{{ 'Tipo'|trans({}, 'newmanagement') }}</th>
      <th style="text-align:right">
        {% if can_write %}
          <button type="button" id="nm-cu-add-btn"
                  class="btn btn-sm btn-outline-secondary"
                  data-action="add_chatbot_user"
                  data-chatbot-id="{{ chatbot_id }}"
                  data-companies-id="{{ companies_id }}"
                  data-url="{{ action_url|e('html_attr') }}"
                  data-csrf="{{ csrf|e('html_attr') }}">
            <i class="ti ti-plus"></i> {{ 'Adicionar'|trans({}, 'newmanagement') }}
          </button>
        {% endif %}
      </th>
    </tr>
  </thead>

  <tbody id="nm-cu-tbody">
    {% for row in users %}
      <tr class="tab_bg_1" id="nm-cu-row-{{ row.id }}">
        <td>{{ row.user_name }}</td>
        <td>{{ row.login }}</td>
        <td>••••••</td>
        <td>{{ row.email }}</td>
        <td>{{ row.user_type }}</td>
        <td>
          {% if can_delete %}
            <button type="button"
                    class="btn btn-sm btn-danger nm-chatbot-del"
                    data-action="delete_chatbot_user"
                    data-id="{{ row.id }}"
                    data-row="nm-cu-row-{{ row.id }}"
                    data-companies-id="{{ companies_id }}"
                    data-url="{{ action_url|e('html_attr') }}"
                    data-csrf="{{ csrf|e('html_attr') }}"
                    data-confirm="{{ 'Remover usuário?'|trans({}, 'newmanagement') }}">
              <i class="ti ti-trash"></i>
            </button>
          {% endif %}
        </td>
      </tr>
    {% endfor %}

    {% if can_write %}
      <tr class="tab_bg_2 nm-add-row" id="nm-cu-add-row">
        <td><input type="text"     id="nm-cu-user_name_0"
             name="chatbot_users[user_name][]"
             class="form-control form-control-sm"
             placeholder="{{ 'Nome'|trans({}, 'newmanagement') }}"></td>
        <td><input type="text"     id="nm-cu-login_0"
             name="chatbot_users[login][]"
             class="form-control form-control-sm"
             placeholder="{{ 'Login'|trans({}, 'newmanagement') }}"></td>
        <td><input type="password" id="nm-cu-password_0"
             name="chatbot_users[password][]"
             class="form-control form-control-sm"
             placeholder="{{ 'Senha'|trans({}, 'newmanagement') }}"
             autocomplete="new-password"></td>
        <td><input type="email"    id="nm-cu-email_0"
             name="chatbot_users[email][]"
             class="form-control form-control-sm"
             placeholder="email@"></td>
        <td>
          <select id="nm-cu-user_type_0"
                  name="chatbot_users[user_type][]"
                  class="form-select form-select-sm">
            <option value="usuario">{{ 'Usuário'|trans({}, 'newmanagement') }}</option>
            <option value="supervisor">{{ 'Supervisor'|trans({}, 'newmanagement') }}</option>
            <option value="administrador">{{ 'Administrador'|trans({}, 'newmanagement') }}</option>
          </select>
        </td>
        <td></td>
      </tr>
    {% endif %}
  </tbody>
</table>
