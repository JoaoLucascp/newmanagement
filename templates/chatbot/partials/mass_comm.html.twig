{#
  templates/chatbot/partials/mass_comm.html.twig
  Tabela de Comunicação em Massa.
  Herda do contexto pai: chatbot_id, companies_id, csrf, action_url, can_write, can_delete, mass_comm
#}
<table class="tab_cadre_fixehov" id="nm-mc-table">
  <thead>
    <tr class="headerRow noHover">
      <th>{{ __('Nome do Sistema', 'newmanagement') }}</th>
      <th>{{ __('Data Ativação', 'newmanagement') }}</th>
      <th>{{ __('Número Autenticado', 'newmanagement') }}</th>
      <th>{{ __('Tipo Homologação', 'newmanagement') }}</th>
      <th>{{ __('Link de Acesso', 'newmanagement') }}</th>
      <th>{{ __('Login', 'newmanagement') }}</th>
      <th>{{ __('Senha', 'newmanagement') }}</th>
      <th style="text-align:right">
        {% if can_write %}
          <button type="button" id="nm-mc-add-btn"
                  class="btn btn-sm btn-outline-secondary"
                  data-action="add_mass_comm"
                  data-chatbot-id="{{ chatbot_id }}"
                  data-companies-id="{{ companies_id }}"
                  data-url="{{ action_url|e('html_attr') }}"
                  data-csrf="{{ csrf|e('html_attr') }}">
            <i class="ti ti-plus"></i> {{ __('Adicionar', 'newmanagement') }}
          </button>
        {% endif %}
      </th>
    </tr>
  </thead>

  <tbody id="nm-mc-tbody">
    {% for row in mass_comm %}
      <tr class="tab_bg_1" id="nm-mc-row-{{ row.id }}">
        <td>{{ row.system_name }}</td>
        <td>{{ row.activation_date }}</td>
        <td>{{ row.authenticated_number }}</td>
        <td>{{ row.homologation_type }}</td>
        <td>
          {% if row.access_link is not empty %}
            <a href="{{ row.access_link|e('html_attr') }}"
               target="_blank" rel="noopener">
              <i class="ti ti-external-link"></i>
            </a>
          {% endif %}
        </td>
        <td>{{ row.login }}</td>
        <td>••••••</td>
        <td>
          {% if can_delete %}
            <button type="button"
                    class="btn btn-sm btn-danger nm-chatbot-del"
                    data-action="delete_mass_comm"
                    data-id="{{ row.id }}"
                    data-row="nm-mc-row-{{ row.id }}"
                    data-companies-id="{{ companies_id }}"
                    data-url="{{ action_url|e('html_attr') }}"
                    data-csrf="{{ csrf|e('html_attr') }}"
                    data-confirm="{{ __('Remover?', 'newmanagement') }}">
              <i class="ti ti-trash"></i>
            </button>
          {% endif %}
        </td>
      </tr>
    {% endfor %}

    {% if can_write %}
      <tr class="tab_bg_2 nm-add-row" id="nm-mc-add-row">
        <td><input type="text"     id="nm-mc-system_name_0"
             name="chatbot_mass_comm[system_name][]"
             class="form-control form-control-sm"
             placeholder="{{ __('Nome', 'newmanagement') }}"></td>
        <td><input type="date"     id="nm-mc-activation_date_0"
             name="chatbot_mass_comm[activation_date][]"
             class="form-control form-control-sm"></td>
        <td><input type="text"     id="nm-mc-authenticated_number_0"
             name="chatbot_mass_comm[authenticated_number][]"
             class="form-control form-control-sm"
             placeholder="5511..."></td>
        <td><input type="text"     id="nm-mc-homologation_type_0"
             name="chatbot_mass_comm[homologation_type][]"
             class="form-control form-control-sm"
             placeholder="Ex: BSP"></td>
        <td><input type="url"      id="nm-mc-access_link_0"
             name="chatbot_mass_comm[access_link][]"
             class="form-control form-control-sm"
             placeholder="https://"></td>
        <td><input type="text"     id="nm-mc-login_0"
             name="chatbot_mass_comm[login][]"
             class="form-control form-control-sm"></td>
        <td><input type="password" id="nm-mc-password_0"
             name="chatbot_mass_comm[password][]"
             class="form-control form-control-sm"
             placeholder="{{ __('Senha', 'newmanagement') }}"
             autocomplete="new-password"></td>
        <td></td>
      </tr>
    {% endif %}
  </tbody>
</table>
