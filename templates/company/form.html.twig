{#
  Newmanagement — Formulário de Empresa
  Variáveis recebidas do PHP (Company::showForm):
    item               — objeto Company com campos em item.fields
    id                 — int: ID do registro (0 = novo)
    id_label           — string: texto a exibir no campo ID (número ou 'Gerado automaticamente')
    contract_options   — array<int, string>: opções do dropdown Status do Contrato
    contract_selected  — int: valor selecionado atualmente
    csrf_token         — string: token CSRF gerado pelo GLPI
    action_url         — string: URL do form action
#}
<tr class="tab_bg_1">
  <td>{{ __('Nome', 'newmanagement') }} <span class="required">*</span></td>
  <td>
    <input type="text" id="name" name="name"
           value="{{ item.fields.name|default('')|e }}"
           class="form-control" required>
  </td>
  <td>{{ __('ID', 'newmanagement') }}</td>
  <td>
    <input type="text" class="form-control"
           value="{{ id_label|e }}" disabled>
  </td>
</tr>

<tr class="tab_bg_1">
  <td>{{ __('CNPJ', 'newmanagement') }}</td>
  <td>
    <div class="input-group">
      <input type="text" id="cnpj" name="cnpj"
             value="{{ item.fields.cnpj|default('')|e }}"
             class="form-control" placeholder="00.000.000/0000-00" maxlength="18">
      <button type="button" class="btn btn-outline-secondary btn-sm"
              id="btn-buscar-cnpj"
              title="{{ __('Buscar CNPJ na BrasilAPI', 'newmanagement') }}">
        <i class="ti ti-search"></i> {{ __('Buscar', 'newmanagement') }}
      </button>
    </div>
    <span id="cnpj-feedback" class="nm-feedback"></span>
  </td>
  <td>{{ __('Razão Social', 'newmanagement') }}</td>
  <td>
    <input type="text" id="razao_social" name="razao_social"
           value="{{ item.fields.razao_social|default('')|e }}"
           class="form-control">
  </td>
</tr>

<tr class="tab_bg_1">
  <td>
    {{ __('E-mail', 'newmanagement') }}
    <i class="ti ti-info-circle ms-1"
       title="{{ __('A Receita Federal pode não disponibilizar este dado. Preencha manualmente se necessário.', 'newmanagement') }}"
       style="cursor:help; color:var(--tblr-secondary);"></i>
  </td>
  <td>
    <input type="email" id="email" name="email"
           value="{{ item.fields.email|default('')|e }}"
           class="form-control">
  </td>
  <td>{{ __('Telefone', 'newmanagement') }}</td>
  <td>
    <input type="text" id="phone" name="phone"
           value="{{ item.fields.phone|default('')|e }}"
           class="form-control" placeholder="(00) 00000-0000">
  </td>
</tr>

<tr class="tab_bg_1">
  <td>{{ __('CEP', 'newmanagement') }}</td>
  <td>
    <div class="input-group">
      <input type="text" id="cep" name="cep"
             value="{{ item.fields.cep|default('')|e }}"
             class="form-control" placeholder="00000-000" maxlength="9">
      <button type="button" class="btn btn-outline-secondary btn-sm"
              id="btn-buscar-cep"
              title="{{ __('Buscar CEP na BrasilAPI', 'newmanagement') }}">
        <i class="ti ti-search"></i> {{ __('Buscar', 'newmanagement') }}
      </button>
    </div>
    <span id="cep-feedback" class="nm-feedback"></span>
  </td>
  <td>{{ __('Status do Contrato', 'newmanagement') }}</td>
  <td>
    <select name="contract_status" class="form-select">
      {% for value, label in contract_options %}
        <option value="{{ value }}"
          {% if value == contract_selected %}selected{% endif %}>
          {{ label }}
        </option>
      {% endfor %}
    </select>
  </td>
</tr>

<tr class="tab_bg_1">
  <td>{{ __('Endereço', 'newmanagement') }}</td>
  <td colspan="3">
    <textarea id="address" name="address" class="form-control" rows="2">{{ item.fields.address|default('')|e }}</textarea>
  </td>
</tr>

<tr class="tab_bg_1">
  <td>{{ __('Comentário', 'newmanagement') }}</td>
  <td colspan="3">
    <textarea id="comment" name="comment" class="form-control" rows="3">{{ item.fields.comment|default('')|e }}</textarea>
  </td>
</tr>
