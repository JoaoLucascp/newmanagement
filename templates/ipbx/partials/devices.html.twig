{#
  Partial: tabela de Dispositivos
  Variáveis herdadas: devices, ipbx_id, companies_id, csrf, action_url, can_write, can_delete
#}
<table class="tab_cadre_fixehov" id="nm-dev-table">
  <thead>
    <tr class="headerRow noHover">
      <th>{{ 'Tipo'|__('newmanagement') }}</th>
      <th>{{ 'IP'|__('newmanagement') }}</th>
      <th>{{ 'Login'|__('newmanagement') }}</th>
      <th>{{ 'Senha'|__('newmanagement') }}</th>
      <th style="text-align:right">
        {% if can_write %}
        <button type="button"
                id="nm-dev-add-btn"
                class="btn btn-sm btn-outline-secondary"
                data-action="add_device"
                data-ipbx-id="{{ ipbx_id }}"
                data-companies-id="{{ companies_id }}"
                data-csrf="{{ csrf|e('html_attr') }}"
                data-url="{{ action_url|e('html_attr') }}"
                {{ ipbx_id == 0 ? 'disabled' }}>
          <i class="ti ti-plus"></i> {{ 'Adicionar Dispositivo'|__('newmanagement') }}
        </button>
        {% endif %}
      </th>
    </tr>
  </thead>
  <tbody id="nm-dev-tbody">
    {% for row in devices %}
    <tr class="tab_bg_1" id="nm-dev-row-{{ row.id }}">
      <td>{{ row.device_type|e }}</td>
      <td>{{ row.ip_address|e }}</td>
      <td>{{ row.login|default('')|e }}</td>
      <td>••••••</td>
      <td>
        {% if can_delete %}
        <button type="button"
                class="btn btn-sm btn-icon nm-del-btn"
                data-action="delete_device"
                data-id="{{ row.id }}"
                data-row="nm-dev-row-{{ row.id }}"
                data-companies-id="{{ companies_id }}"
                data-csrf="{{ csrf|e('html_attr') }}"
                data-url="{{ action_url|e('html_attr') }}"
                data-confirm="{{ 'Remover dispositivo?'|__('newmanagement') }}"
                title="{{ 'Remover'|__('newmanagement') }}">
          <i class="ti ti-trash text-danger"></i>
        </button>
        {% endif %}
      </td>
    </tr>
    {% endfor %}

    {% if can_write %}
    <tr class="tab_bg_2" id="nm-dev-add-row">
      <td><input type="text" id="nm-dev-device_type" autocomplete="off" class="form-control form-control-sm" placeholder="{{ 'Tipo'|__('newmanagement') }}"></td>
      <td><input type="text" id="nm-dev-ip_address" autocomplete="off" class="form-control form-control-sm" placeholder="IP"></td>
      <td><input type="text" id="nm-dev-login" autocomplete="off" class="form-control form-control-sm" placeholder="{{ 'Login'|__('newmanagement') }}"></td>
      <td><input type="password" id="nm-dev-password" class="form-control form-control-sm" placeholder="{{ 'Senha'|__('newmanagement') }}" autocomplete="new-password"></td>
      <td></td>
    </tr>
    {% endif %}
  </tbody>
</table>
