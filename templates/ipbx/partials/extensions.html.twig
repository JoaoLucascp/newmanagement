{#
  Partial: Tabela de Ramais
  Colunas: Ramal | Senha | Usuário | IP Dispositivo | Departamento | Grava | LOF | LOC | DDF | DDC | DDI | SRV | [Ações]
#}
{% set ext_pages = ext_page_size > 0 ? max(1, (ext_total / ext_page_size)|round(0, 'ceil')) : 1 %}

<div id="nm-ext-section"
     data-section="extensions"
     data-ipbx-id="{{ ipbx_id }}"
     data-companies-id="{{ companies_id }}"
     data-paginate-url="{{ paginate_url|e('html_attr') }}"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-page="{{ ext_page }}"
     data-page-size="{{ ext_page_size }}"
     data-total="{{ ext_total }}">

  <table class="tab_cadre_fixehov" id="nm-ext-table">
    <thead>
      <tr class="headerRow noHover">
        <th>{{ __('Ramal', 'newmanagement') }}</th>
        <th>{{ __('Senha', 'newmanagement') }}</th>
        <th>{{ __('Usuário', 'newmanagement') }}</th>
        <th>{{ __('IP Dispositivo', 'newmanagement') }}</th>
        <th>{{ __('Departamento', 'newmanagement') }}</th>
        <th class="text-center">{{ __('Grava', 'newmanagement') }}</th>
        <th class="text-center" title="Liga Ocupado Frente">LOF</th>
        <th class="text-center" title="Liga Ocupado Congestionado">LOC</th>
        <th class="text-center" title="Discagem Direta para Fixo">DDF</th>
        <th class="text-center" title="Discagem Direta para Celular">DDC</th>
        <th class="text-center" title="Discagem Direta Internacional">DDI</th>
        <th class="text-center" title="Serviço">SRV</th>
        <th style="text-align:right">
          {% if can_write and ipbx_id > 0 %}
            <button type="button" id="nm-ext-add-btn"
                    class="btn btn-sm btn-outline-secondary"
                    data-action="add_extension"
                    data-ipbx-id="{{ ipbx_id }}"
                    data-companies-id="{{ companies_id }}"
                    data-url="{{ action_url|e('html_attr') }}"
                    data-csrf="{{ csrf|e('html_attr') }}">
              <i class="ti ti-plus"></i> {{ __('Adicionar', 'newmanagement') }}
            </button>
          {% endif %}
        </th>
      </tr>
    </thead>

    <tbody id="nm-ext-tbody">

      {# Linhas salvas #}
      {% for row in extensions %}
        <tr class="tab_bg_1 nm-ext-saved-row" id="nm-ext-row-{{ row.id }}">
          <td>{{ row.number|e }}</td>
          <td><code>{{ row.password|default('')|e }}</code></td>
          <td>{{ row.user_name|default('')|e }}</td>
          <td>{{ row.device_ip|default('')|e }}</td>
          <td>{{ row.department|default('')|e }}</td>
          <td class="text-center">
            <span class="badge {{ row.records_calls ? 'bg-success' : 'bg-secondary' }}">
              {{ row.records_calls ? __('Sim', 'newmanagement') : __('Não', 'newmanagement') }}
            </span>
          </td>
          {% for field in ['lof','loc','ddf','ddc','ddi','srv'] %}
          <td class="text-center" style="min-width:52px">
            <div class="form-check form-switch d-flex justify-content-center m-0 p-0">
              <input class="form-check-input nm-toggle-bool" type="checkbox" role="switch"
                     data-row-id="{{ row.id }}"
                     data-field="{{ field }}"
                     data-action-url="{{ action_url|e('html_attr') }}"
                     data-companies-id="{{ companies_id }}"
                     data-csrf="{{ csrf|e('html_attr') }}"
                     {{ attribute(row, field) ? 'checked' }}
                     style="cursor:pointer">
            </div>
          </td>
          {% endfor %}
          <td>
            {% if can_delete %}
            <button type="button"
                    class="btn btn-sm btn-icon nm-ext-delete"
                    data-id="{{ row.id }}"
                    data-action-url="{{ action_url|e('html_attr') }}"
                    data-companies-id="{{ companies_id }}"
                    data-csrf="{{ csrf|e('html_attr') }}"
                    title="{{ __('Remover ramal', 'newmanagement') }}">
              <i class="ti ti-trash text-danger"></i>
            </button>
            {% endif %}
          </td>
        </tr>
      {% endfor %}

      {# Linha de input — template para novo ramal #}
      {% if can_write and ipbx_id > 0 %}
      <tr class="tab_bg_1 nm-input-row" id="nm-ext-add-row">
        <td><input type="text"     id="nm-ext-number"       name="nm-ext-number"       class="form-control form-control-sm" placeholder="{{ __('Ramal', 'newmanagement') }}"></td>
        <td><input type="password" id="nm-ext-password"     name="nm-ext-password"     class="form-control form-control-sm" placeholder="{{ __('Senha', 'newmanagement') }}" autocomplete="new-password"></td>
        <td><input type="text"     id="nm-ext-user_name"    name="nm-ext-user_name"    class="form-control form-control-sm" placeholder="{{ __('Usuário', 'newmanagement') }}"></td>
        <td><input type="text"     id="nm-ext-device_ip"    name="nm-ext-device_ip"    class="form-control form-control-sm" placeholder="192.168.x.x"></td>
        <td><input type="text"     id="nm-ext-department"   name="nm-ext-department"   class="form-control form-control-sm" placeholder="{{ __('Departamento', 'newmanagement') }}"></td>
        <td class="text-center">
          <select id="nm-ext-records_calls" name="nm-ext-records_calls" class="form-select form-select-sm">
            <option value="0">{{ __('Não', 'newmanagement') }}</option>
            <option value="1">{{ __('Sim', 'newmanagement') }}</option>
          </select>
        </td>
        {% for field in ['lof','loc','ddf','ddc','ddi','srv'] %}
        <td class="text-center" style="min-width:52px">
          <div class="form-check form-switch d-flex justify-content-center m-0 p-0">
            <input class="form-check-input" type="checkbox" id="nm-ext-{{ field }}" name="nm-ext-{{ field }}" value="1" style="cursor:pointer">
          </div>
        </td>
        {% endfor %}
        <td>
          <button type="button" class="btn btn-sm btn-icon nm-row-del-btn" title="{{ __('Remover linha', 'newmanagement') }}">
            <i class="ti ti-trash text-danger"></i>
          </button>
        </td>
      </tr>
      {% endif %}

      {# Mensagem vazia #}
      {% if extensions is empty and (not can_write or ipbx_id <= 0) %}
        <tr id="nm-ext-empty">
          <td colspan="13" class="text-center text-muted py-3">
            {{ __('Nenhum ramal cadastrado.', 'newmanagement') }}
          </td>
        </tr>
      {% endif %}

    </tbody>
  </table>

  {# Paginação #}
  <div id="nm-ext-pagination"
       class="d-flex align-items-center justify-content-between mt-2"
       {% if ext_pages <= 1 %}style="display:none!important"{% endif %}>
    <span class="text-muted" style="font-size:0.8rem">
      {{ __('Mostrando', 'newmanagement') }}
      {{ ((ext_page - 1) * ext_page_size) + 1 }}–{{ min(ext_page * ext_page_size, ext_total) }}
      {{ __('de', 'newmanagement') }} {{ ext_total }}
      {{ __('ramais', 'newmanagement') }}
    </span>
    <div class="d-flex gap-1">
      <button type="button" class="btn btn-sm btn-outline-secondary nm-page-btn"
              data-section-id="nm-ext-section" data-dir="prev"
              {% if ext_page <= 1 %}disabled{% endif %}
              title="{{ __('Página anterior', 'newmanagement') }}">
        <i class="ti ti-chevron-left"></i>
      </button>
      <span class="btn btn-sm disabled px-3" style="min-width:90px;text-align:center">
        {{ ext_page }} / {{ ext_pages }}
      </span>
      <button type="button" class="btn btn-sm btn-outline-secondary nm-page-btn"
              data-section-id="nm-ext-section" data-dir="next"
              {% if ext_page >= ext_pages %}disabled{% endif %}
              title="{{ __('Próxima página', 'newmanagement') }}">
        <i class="ti ti-chevron-right"></i>
      </button>
    </div>
  </div>

</div>
