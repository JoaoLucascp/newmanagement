{#
  Newmanagement - Aba IPBX On-Premise dentro da ficha de Empresa
  Variaveis recebidas (Ipbx::showTabForCompany):
    action_url, companies_id, ipbx_id, fields, ipbx_action, csrf,
    can_write, can_delete, web_placeholder, ssh_placeholder,
    extensions, devices, network, ext_total, dev_total, net_total.
#}
<div class="nm-ipbx-tab nm-ipbx-page"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-companies-id="{{ companies_id }}">

  <div id="nm-ipbx-form" class="nm-ipbx-form-panel">
    <input type="hidden" id="nm-ipbx-csrf"         value="{{ csrf|e('html_attr') }}">
    <input type="hidden" id="nm-ipbx-action"       value="{{ ipbx_action }}">
    <input type="hidden" id="nm-ipbx-id"           value="{{ ipbx_id }}">
    <input type="hidden" id="nm-ipbx-companies-id" value="{{ companies_id }}">

    <div class="nm-section-heading">
      <div class="nm-section-title">
        <i class="ti ti-server" aria-hidden="true"></i>
        <span>{{ __('Servidor IPBX', 'newmanagement') }}</span>
      </div>
      {% if ipbx_id > 0 %}
        <span class="badge bg-secondary-lt">ID {{ ipbx_id }}</span>
      {% endif %}
    </div>

    <div class="nm-ipbx-grid">
      <div class="nm-field">
        <label class="form-label" for="nm-ipbx-model">{{ __('Modelo', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-model" autocomplete="off"
               value="{{ fields.model|default('')|e }}"
               class="form-control"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field">
        <label class="form-label" for="nm-ipbx-server_version">{{ __('Versão', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-server_version" autocomplete="off"
               value="{{ fields.server_version|default('')|e }}"
               class="form-control"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field">
        <label class="form-label" for="nm-ipbx-ip_local">{{ __('IP Local', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-ip_local" autocomplete="off"
               value="{{ fields.ip_local|default('')|e }}"
               class="form-control" placeholder="192.168.1.1"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field">
        <label class="form-label" for="nm-ipbx-ip_external">{{ __('IP Externo', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-ip_external" autocomplete="off"
               value="{{ fields.ip_external|default('')|e }}"
               class="form-control" placeholder="201.x.x.x"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field nm-field--compact">
        <label class="form-label" for="nm-ipbx-web_port">{{ __('Porta Web', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-web_port" autocomplete="off"
               value="{{ fields.web_port|default('')|e }}"
               class="form-control" placeholder="80"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field">
        <label class="form-label" for="nm-web-password">{{ __('Senha Web', 'newmanagement') }}</label>
        <div class="input-group nm-password-group">
          <input type="password" id="nm-web-password"
                 class="form-control" autocomplete="new-password"
                 value=""
                 placeholder="{{ web_placeholder|e('html_attr') }}"
                 {{ not can_write ? 'readonly' }}>
          <button type="button" class="btn btn-icon nm-btn-eye"
                  data-target="nm-web-password"
                  title="{{ __('Mostrar ou ocultar senha', 'newmanagement') }}">
            <i class="ti ti-eye"></i>
          </button>
        </div>
      </div>

      <div class="nm-field nm-field--compact">
        <label class="form-label" for="nm-ipbx-ssh_port">{{ __('Porta SSH', 'newmanagement') }}</label>
        <input type="text" id="nm-ipbx-ssh_port" autocomplete="off"
               value="{{ fields.ssh_port|default('')|e }}"
               class="form-control" placeholder="22"
               {{ not can_write ? 'readonly' }}>
      </div>

      <div class="nm-field">
        <label class="form-label" for="nm-ssh-password">{{ __('Senha SSH', 'newmanagement') }}</label>
        <div class="input-group nm-password-group">
          <input type="password" id="nm-ssh-password"
                 class="form-control" autocomplete="new-password"
                 value=""
                 placeholder="{{ ssh_placeholder|e('html_attr') }}"
                 {{ not can_write ? 'readonly' }}>
          <button type="button" class="btn btn-icon nm-btn-eye"
                  data-target="nm-ssh-password"
                  title="{{ __('Mostrar ou ocultar senha', 'newmanagement') }}">
            <i class="ti ti-eye"></i>
          </button>
        </div>
      </div>

      <div class="nm-field nm-field--full">
        <label class="form-label" for="nm-ipbx-comment">{{ __('Comentário', 'newmanagement') }}</label>
        <textarea id="nm-ipbx-comment" class="form-control" rows="3"
                  {{ not can_write ? 'readonly' }}>{{ fields.comment|default('')|e }}</textarea>
      </div>
    </div>
  </div>

  <div class="nm-tabs-wrapper nm-ipbx-tabs">
    <div class="nm-tab-bar" role="tablist" aria-label="{{ __('Recursos do IPBX', 'newmanagement') }}">
      <button type="button"
              class="nm-tab active"
              role="tab"
              aria-selected="true"
              aria-controls="nm-panel-ext"
              id="nm-tab-ext"
              data-panel="nm-panel-ext">
        <i class="ti ti-phone-call" aria-hidden="true"></i>
        {{ __('Ramais', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-ext">{{ ext_total }}</span>
      </button>

      <button type="button"
              class="nm-tab"
              role="tab"
              aria-selected="false"
              aria-controls="nm-panel-dev"
              id="nm-tab-dev"
              data-panel="nm-panel-dev">
        <i class="ti ti-device-desktop" aria-hidden="true"></i>
        {{ __('Dispositivos', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-dev">{{ dev_total }}</span>
      </button>

      <button type="button"
              class="nm-tab"
              role="tab"
              aria-selected="false"
              aria-controls="nm-panel-net"
              id="nm-tab-net"
              data-panel="nm-panel-net">
        <i class="ti ti-network" aria-hidden="true"></i>
        {{ __('Rede da Empresa', 'newmanagement') }}
        <span class="nm-tab-count" id="nm-count-net">{{ net_total }}</span>
      </button>
    </div>

    <div class="nm-tab-panel active" id="nm-panel-ext" role="tabpanel" aria-labelledby="nm-tab-ext">
      {% include '@newmanagement/ipbx/partials/extensions.html.twig' %}
    </div>

    <div class="nm-tab-panel" id="nm-panel-dev" role="tabpanel" aria-labelledby="nm-tab-dev" hidden>
      {% include '@newmanagement/ipbx/partials/devices.html.twig' %}
    </div>

    <div class="nm-tab-panel" id="nm-panel-net" role="tabpanel" aria-labelledby="nm-tab-net" hidden>
      {% include '@newmanagement/ipbx/partials/network.html.twig' %}
    </div>
  </div>

  {% if can_write %}
  <div class="nm-ipbx-savebar">
    <button type="button" id="nm-save-all"
            class="btn btn-primary"
            data-action-url="{{ action_url|e('html_attr') }}">
      <i class="ti ti-device-floppy"></i>
      {{ __('Salvar', 'newmanagement') }}
    </button>
  </div>
  {% endif %}
</div>
