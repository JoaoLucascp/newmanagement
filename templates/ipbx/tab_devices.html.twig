{#
  templates/ipbx/tab_devices.html.twig
  Aba de Dispositivos dentro da ficha do IPBX On-Premise.

  Variáveis recebidas de IpbxDevice::showForIpbx():
    rows, ipbx_id, companies_id, can_write, can_delete, csrf, action_url
#}
<div class="nm-dev-tab"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-ipbx-id="{{ ipbx_id }}"
     data-companies-id="{{ companies_id }}">

  {# === Lista de dispositivos === #}
  <table class="tab_cadre_fixe">
    <thead>
      <tr class="tab_bg_2">
        <th>{{ 'Tipo'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'IP'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Login'|trans({}, 'newmanagement') }}</th>
        {% if can_delete %}<th></th>{% endif %}
      </tr>
    </thead>
    <tbody id="nm-dev-rows">
      {% for row in rows %}
      <tr id="nm-dev-row-{{ row.id }}">
        <td>{{ row.device_type|default('-')|e }}</td>
        <td>{{ row.ip_address|default('-')|e }}</td>
        <td>{{ row.login|default('-')|e }}</td>
        {% if can_delete %}
        <td>
          <button type="button" class="btn btn-sm btn-danger nm-dev-delete"
                  data-id="{{ row.id }}"
                  data-csrf="{{ csrf|e('html_attr') }}">
            <i class="ti ti-trash"></i>
          </button>
        </td>
        {% endif %}
      </tr>
      {% else %}
      <tr id="nm-dev-empty">
        <td colspan="{{ can_delete ? 4 : 3 }}" class="text-center text-muted py-3">
          {{ 'Nenhum dispositivo cadastrado.'|trans({}, 'newmanagement') }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {# === Formulário de adição === #}
  {% if can_write %}
  <div class="card mt-3">
    <div class="card-header">
      <strong>{{ 'Adicionar Dispositivo'|trans({}, 'newmanagement') }}</strong>
    </div>
    <div class="card-body">
      <input type="hidden" id="nm-dev-csrf"         value="{{ csrf|e('html_attr') }}">
      <input type="hidden" id="nm-dev-ipbx-id"      value="{{ ipbx_id }}">
      <input type="hidden" id="nm-dev-companies-id" value="{{ companies_id }}">

      <table class="tab_cadre_fixe">
        <tr class="tab_bg_1">
          <td>{{ 'Tipo de Dispositivo'|trans({}, 'newmanagement') }} <span class="text-danger">*</span></td>
          <td><input type="text" id="nm-dev-device_type" class="form-control" placeholder="Ex: Gateway, ATA, Switch"></td>
          <td>{{ 'Endereço IP'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-dev-ip_address"  class="form-control" placeholder="Ex: 192.168.1.x"></td>
        </tr>
        <tr class="tab_bg_1">
          <td>{{ 'Login'|trans({}, 'newmanagement') }}</td>
          <td><input type="text"     id="nm-dev-login"    class="form-control"></td>
          <td>{{ 'Senha'|trans({}, 'newmanagement') }}</td>
          <td><input type="password" id="nm-dev-password" class="form-control" autocomplete="new-password"></td>
        </tr>
      </table>

      <div class="d-flex justify-content-end mt-3">
        <button type="button" id="nm-dev-save" class="btn btn-primary">
          <i class="ti ti-plus" id="nm-dev-save-icon"></i>
          {{ 'Adicionar Dispositivo'|trans({}, 'newmanagement') }}
        </button>
      </div>
    </div>
  </div>
  {% endif %}

</div>

<script>
(function () {
  'use strict';

  const tab = document.querySelector('.nm-dev-tab');
  if (!tab) return;

  const actionUrl   = tab.dataset.actionUrl;
  const ipbxId      = tab.dataset.ipbxId;
  const companiesId = tab.dataset.companiesId;

  function get(id) {
    const el = document.getElementById('nm-dev-' + id);
    return el ? el.value : '';
  }

  async function nmPost(body) {
    const fd = new FormData();
    for (const [k, v] of Object.entries(body)) fd.append(k, v ?? '');
    const r = await fetch(actionUrl, { method: 'POST', body: fd, signal: AbortSignal.timeout(10000) });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  }

  function setIcon(btn, icon, spin) {
    const i = btn.querySelector('i');
    if (i) { i.className = 'ti ' + icon + (spin ? ' nm-spin' : ''); }
    btn.disabled = spin;
  }

  // --- ADICIONAR ---
  const saveBtn = document.getElementById('nm-dev-save');
  if (saveBtn) {
    saveBtn.addEventListener('click', async () => {
      const type = get('device_type');
      if (!type) { document.getElementById('nm-dev-device_type').focus(); return; }

      setIcon(saveBtn, 'ti-loader-2', true);
      try {
        const data = await nmPost({
          _glpi_csrf_token : get('csrf'),
          action           : 'add_device',
          ipbx_id          : ipbxId,
          companies_id     : companiesId,
          device_type      : type,
          ip_address       : get('ip_address'),
          login            : get('login'),
          password         : get('password'),
        });

        if (!data.success) throw new Error(data.error || 'Erro');

        const tbody = document.getElementById('nm-dev-rows');
        const empty = document.getElementById('nm-dev-empty');
        if (empty) empty.remove();
        if (data.html) {
          tbody.insertAdjacentHTML('beforeend', data.html);
          bindDeleteButtons();
        }

        ['device_type','ip_address','login','password'].forEach(f => {
          const el = document.getElementById('nm-dev-' + f);
          if (el) el.value = '';
        });

        setIcon(saveBtn, 'ti-check', false);
        setTimeout(() => setIcon(saveBtn, 'ti-plus', false), 2000);

      } catch (err) {
        setIcon(saveBtn, 'ti-x', false);
        setTimeout(() => setIcon(saveBtn, 'ti-plus', false), 3000);
      }
    });
  }

  // --- EXCLUIR ---
  function bindDeleteButtons() {
    document.querySelectorAll('.nm-dev-delete').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!confirm('{{ 'Excluir este dispositivo?'|trans({}, 'newmanagement') }}')) return;
        btn.disabled = true;
        try {
          const data = await nmPost({
            _glpi_csrf_token : btn.dataset.csrf,
            action           : 'delete_device',
            id               : btn.dataset.id,
            companies_id     : companiesId,
          });
          if (!data.success) throw new Error(data.error || 'Erro');
          document.getElementById('nm-dev-row-' + btn.dataset.id)?.remove();
        } catch (err) { btn.disabled = false; }
      });
    });
  }
  bindDeleteButtons();

  if (!document.getElementById('nm-spin-style')) {
    const s = document.createElement('style');
    s.id = 'nm-spin-style';
    s.textContent = '@keyframes nm-spin{to{transform:rotate(360deg)}}.nm-spin{animation:nm-spin .8s linear infinite}';
    document.head.appendChild(s);
  }

}());
</script>
