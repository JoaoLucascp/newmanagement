{#
  templates/ipbx/tab_network.html.twig
  Aba de Rede dentro da ficha do IPBX On-Premise.

  Variáveis recebidas de IpbxNetwork::showForIpbx():
    rows, ipbx_id, companies_id, can_write, can_delete, csrf, action_url
#}
<div class="nm-net-tab"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-ipbx-id="{{ ipbx_id }}"
     data-companies-id="{{ companies_id }}">

  {# === Formulário de adição (topo) === #}
  {% if can_write %}
  <div class="card mb-3">
    <div class="card-header">
      <strong>{{ 'Adicionar Rede'|trans({}, 'newmanagement') }}</strong>
    </div>
    <div class="card-body">
      <input type="hidden" id="nm-net-ipbx-id"      value="{{ ipbx_id }}">
      <input type="hidden" id="nm-net-companies-id" value="{{ companies_id }}">

      <table class="tab_cadre_fixe">
        <tr class="tab_bg_1">
          <td>{{ 'Rede IP'|trans({}, 'newmanagement') }} <span class="text-danger">*</span></td>
          <td><input type="text" id="nm-net-ip_network"    class="form-control" placeholder="Ex: 192.168.1.0"></td>
          <td>{{ 'Máscara'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-net-netmask"       class="form-control" placeholder="Ex: 255.255.255.0"></td>
        </tr>
        <tr class="tab_bg_1">
          <td>{{ 'Gateway'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-net-gateway"       class="form-control" placeholder="Ex: 192.168.1.1"></td>
          <td>{{ 'Provedor'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-net-supplier"      class="form-control" placeholder="Ex: Vivo Empresas"></td>
        </tr>
        <tr class="tab_bg_1">
          <td>{{ 'DNS Primário'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-net-dns_primary"   class="form-control" placeholder="Ex: 8.8.8.8"></td>
          <td>{{ 'DNS Secundário'|trans({}, 'newmanagement') }}</td>
          <td><input type="text" id="nm-net-dns_secondary" class="form-control" placeholder="Ex: 8.8.4.4"></td>
        </tr>
      </table>

      <div class="d-flex justify-content-end mt-3">
        <button type="button" id="nm-net-save" class="btn btn-primary">
          <i class="ti ti-plus"></i>
          {{ 'Adicionar Rede'|trans({}, 'newmanagement') }}
        </button>
      </div>
    </div>
  </div>
  {% endif %}

  {# === Lista de redes (abaixo do formulário) === #}
  <table class="tab_cadre_fixe">
    <thead>
      <tr class="tab_bg_2">
        <th>{{ 'Rede'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Máscara'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Gateway'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'DNS Primário'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'DNS Secundário'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Provedor'|trans({}, 'newmanagement') }}</th>
        {% if can_delete %}<th></th>{% endif %}
      </tr>
    </thead>
    <tbody id="nm-net-rows">
      {% for row in rows %}
      <tr id="nm-net-row-{{ row.id }}">
        <td>{{ row.ip_network|default('-')|e }}</td>
        <td>{{ row.netmask|default('-')|e }}</td>
        <td>{{ row.gateway|default('-')|e }}</td>
        <td>{{ row.dns_primary|default('-')|e }}</td>
        <td>{{ row.dns_secondary|default('-')|e }}</td>
        <td>{{ row.supplier|default('-')|e }}</td>
        {% if can_delete %}
        <td>
          <button type="button" class="btn btn-sm btn-danger nm-net-delete"
                  data-id="{{ row.id }}">
            <i class="ti ti-trash"></i>
          </button>
        </td>
        {% endif %}
      </tr>
      {% else %}
      <tr id="nm-net-empty">
        <td colspan="{{ can_delete ? 7 : 6 }}" class="text-center text-muted py-3">
          {{ 'Nenhuma rede cadastrada.'|trans({}, 'newmanagement') }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

</div>

<script>
(function () {
  'use strict';

  const tab = document.querySelector('.nm-net-tab');
  if (!tab) return;

  const actionUrl   = tab.dataset.actionUrl;
  const ipbxId      = tab.dataset.ipbxId;
  const companiesId = tab.dataset.companiesId;

  function nmCsrf() {
    const meta = document.querySelector('meta[property="glpi:csrf_token"]');
    if (meta && meta.getAttribute('content')) return meta.getAttribute('content');
    const h = document.querySelector('input[name="_glpi_csrf_token"]');
    return h ? h.value : '';
  }

  function get(id) {
    const el = document.getElementById('nm-net-' + id);
    return el ? el.value : '';
  }

  async function nmPost(body) {
    const csrf = nmCsrf();
    const fd = new FormData();
    fd.append('_glpi_csrf_token', csrf);
    for (const [k, v] of Object.entries(body)) {
      if (k !== '_glpi_csrf_token') fd.append(k, v ?? '');
    }
    const r = await fetch(actionUrl, {
      method : 'POST',
      headers: { 'X-Glpi-Csrf-Token': csrf },
      body   : fd,
      signal : AbortSignal.timeout(10000),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const json = await r.json();
    if (json && json.csrf) {
      const meta = document.querySelector('meta[property="glpi:csrf_token"]');
      if (meta) meta.setAttribute('content', json.csrf);
    }
    return json;
  }

  function setIcon(btn, icon, spin) {
    const i = btn.querySelector('i');
    if (i) { i.className = 'ti ' + icon + (spin ? ' nm-spin' : ''); }
    btn.disabled = spin;
  }

  const saveBtn = document.getElementById('nm-net-save');
  if (saveBtn) {
    saveBtn.addEventListener('click', async () => {
      const network = get('ip_network');
      if (!network) { document.getElementById('nm-net-ip_network').focus(); return; }

      setIcon(saveBtn, 'ti-loader-2', true);
      try {
        const data = await nmPost({
          action        : 'add_network',
          ipbx_id       : ipbxId,
          companies_id  : companiesId,
          ip_network    : network,
          netmask       : get('netmask'),
          gateway       : get('gateway'),
          dns_primary   : get('dns_primary'),
          dns_secondary : get('dns_secondary'),
          supplier      : get('supplier'),
        });

        if (!data.success) throw new Error(data.error || 'Erro');

        const tbody = document.getElementById('nm-net-rows');
        const empty = document.getElementById('nm-net-empty');
        if (empty) empty.remove();
        if (data.html) {
          tbody.insertAdjacentHTML('beforeend', data.html);
          bindDeleteButtons();
        }

        ['ip_network','netmask','gateway','dns_primary','dns_secondary','supplier'].forEach(f => {
          const el = document.getElementById('nm-net-' + f);
          if (el) el.value = '';
        });

        setIcon(saveBtn, 'ti-check', false);
        setTimeout(() => setIcon(saveBtn, 'ti-plus', false), 2000);

      } catch (err) {
        console.error('[NM-net] Erro:', err.message);
        setIcon(saveBtn, 'ti-x', false);
        setTimeout(() => setIcon(saveBtn, 'ti-plus', false), 3000);
      }
    });
  }

  function bindDeleteButtons() {
    document.querySelectorAll('.nm-net-delete').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!confirm('{{ 'Excluir esta rede?'|trans({}, 'newmanagement') }}')) return;
        btn.disabled = true;
        try {
          const data = await nmPost({
            action       : 'delete_network',
            id           : btn.dataset.id,
            companies_id : companiesId,
          });
          if (!data.success) throw new Error(data.error || 'Erro');
          document.getElementById('nm-net-row-' + btn.dataset.id)?.remove();
        } catch (err) { btn.disabled = false; }
      });
    });
  }
  bindDeleteButtons();

  if (!document.getElementById('nm-spin-style')) {
    const s = document.createElement('style');
    s.id = 'nm-spin-style';
    s.textContent = '@keyframes nm-spin{to{transform:rotate(360deg)}}.nm-spin{animation:nm-spin .8s linear infinite}';
    document.head.appendChild(s);
  }

}());
</script>
