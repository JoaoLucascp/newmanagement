{#
  templates/ipbx/tab_network.html.twig
  Aba de Rede — padrão GLPI 11: linha inline criada pelo botão '+ Adicionar'.

  Variáveis recebidas de IpbxNetwork::showForIpbx():
    rows, ipbx_id, companies_id, can_write, can_delete, csrf, action_url
#}
<div class="nm-net-tab"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-ipbx-id="{{ ipbx_id }}"
     data-companies-id="{{ companies_id }}">

  <table class="tab_cadre_fixe" id="nm-net-list">
    <thead>
      <tr class="tab_bg_2">
        <th>{{ 'Rede IP'|trans({}, 'newmanagement') }} <span class="text-danger">*</span></th>
        <th>{{ 'Máscara'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Gateway'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'DNS Primário'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'DNS Secundário'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Provedor'|trans({}, 'newmanagement') }}</th>
        <th style="width:120px;">
          {% if can_write %}
          <button type="button" id="nm-net-add-btn" class="btn btn-sm btn-primary">
            <i class="ti ti-plus"></i> {{ '+ Adicionar'|trans({}, 'newmanagement') }}
          </button>
          {% endif %}
        </th>
      </tr>
    </thead>
    <tbody id="nm-net-rows">
      {% for row in rows %}
      <tr id="nm-net-row-{{ row.id }}">
        <td>{{ row.ip_network|default('-')|e }}</td>
        <td>{{ row.netmask|default('-')|e }}</td>
        <td>{{ row.gateway|default('-')|e }}</td>
        <td>{{ row.dns_primary|default('-')|e }}</td>
        <td>{{ row.dns_secondary|default('-')|e }}</td>
        <td>{{ row.supplier|default('-')|e }}</td>
        <td>
          {% if can_delete %}
          <button type="button" class="btn btn-sm btn-danger nm-net-delete" data-id="{{ row.id }}">
            <i class="ti ti-trash"></i>
          </button>
          {% endif %}
        </td>
      </tr>
      {% else %}
      <tr id="nm-net-empty">
        <td colspan="7" class="text-center text-muted py-3">
          <i class="ti ti-wifi-off me-1"></i>
          {{ 'Nenhuma rede cadastrada. Clique em + Adicionar para incluir.'|trans({}, 'newmanagement') }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

</div>

<script>
(function () {
  'use strict';

  const tab = document.querySelector('.nm-net-tab');
  if (!tab) return;

  const actionUrl   = tab.dataset.actionUrl;
  const ipbxId      = tab.dataset.ipbxId;
  const companiesId = tab.dataset.companiesId;

  function nmCsrf() {
    const meta = document.querySelector('meta[property="glpi:csrf_token"]');
    if (meta && meta.getAttribute('content')) return meta.getAttribute('content');
    const h = document.querySelector('input[name="_glpi_csrf_token"]');
    return h ? h.value : '';
  }

  async function nmPost(body) {
    const csrf = nmCsrf();
    const fd = new FormData();
    fd.append('_glpi_csrf_token', csrf);
    for (const [k, v] of Object.entries(body)) {
      if (k !== '_glpi_csrf_token') fd.append(k, v ?? '');
    }
    const r = await fetch(actionUrl, {
      method : 'POST',
      headers: { 'X-Glpi-Csrf-Token': csrf },
      body   : fd,
      signal : AbortSignal.timeout(10000),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const json = await r.json();
    if (json && json.csrf) {
      const meta = document.querySelector('meta[property="glpi:csrf_token"]');
      if (meta) meta.setAttribute('content', json.csrf);
    }
    return json;
  }

  function setIcon(btn, icon, spin) {
    const i = btn.querySelector('i');
    if (i) i.className = 'ti ' + icon + (spin ? ' nm-spin' : '');
    btn.disabled = spin;
  }

  /* ── Botão '+ Adicionar' ───────────────────────────── */
  const addBtn = document.getElementById('nm-net-add-btn');
  if (addBtn) {
    addBtn.addEventListener('click', () => {
      const tbody = document.getElementById('nm-net-rows');
      const empty = document.getElementById('nm-net-empty');
      if (empty) empty.remove();

      const tr = document.createElement('tr');
      tr.className = 'nm-net-new-row';
      tr.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" id="nm-net-ip_network"    placeholder="Ex: 192.168.1.0" required></td>
        <td><input type="text" class="form-control form-control-sm" id="nm-net-netmask"       placeholder="255.255.255.0"></td>
        <td><input type="text" class="form-control form-control-sm" id="nm-net-gateway"       placeholder="192.168.1.1"></td>
        <td><input type="text" class="form-control form-control-sm" id="nm-net-dns_primary"   placeholder="8.8.8.8"></td>
        <td><input type="text" class="form-control form-control-sm" id="nm-net-dns_secondary" placeholder="8.8.4.4"></td>
        <td><input type="text" class="form-control form-control-sm" id="nm-net-supplier"      placeholder="Ex: Vivo Empresas"></td>
        <td class="d-flex gap-1">
          <button type="button" class="btn btn-sm btn-success" id="nm-net-save-inline">
            <i class="ti ti-device-floppy"></i>
          </button>
          <button type="button" class="btn btn-sm btn-secondary" id="nm-net-cancel-inline">
            <i class="ti ti-x"></i>
          </button>
        </td>`;
      tbody.appendChild(tr);
      tr.querySelector('#nm-net-ip_network').focus();

      tr.querySelector('#nm-net-cancel-inline').addEventListener('click', () => {
        tr.remove();
        if (!document.querySelector('#nm-net-rows tr:not(.nm-net-new-row)')) {
          const emptyTr = document.createElement('tr');
          emptyTr.id = 'nm-net-empty';
          emptyTr.innerHTML = `<td colspan="7" class="text-center text-muted py-3"><i class="ti ti-wifi-off me-1"></i>Nenhuma rede cadastrada. Clique em + Adicionar para incluir.</td>`;
          document.getElementById('nm-net-rows').appendChild(emptyTr);
        }
      });

      const saveInline = tr.querySelector('#nm-net-save-inline');
      saveInline.addEventListener('click', async () => {
        const network = tr.querySelector('#nm-net-ip_network').value.trim();
        if (!network) { tr.querySelector('#nm-net-ip_network').focus(); return; }

        setIcon(saveInline, 'ti-loader-2', true);
        try {
          const data = await nmPost({
            action        : 'add_network',
            ipbx_id       : ipbxId,
            companies_id  : companiesId,
            ip_network    : network,
            netmask       : tr.querySelector('#nm-net-netmask').value,
            gateway       : tr.querySelector('#nm-net-gateway').value,
            dns_primary   : tr.querySelector('#nm-net-dns_primary').value,
            dns_secondary : tr.querySelector('#nm-net-dns_secondary').value,
            supplier      : tr.querySelector('#nm-net-supplier').value,
          });

          if (!data.success) throw new Error(data.error || 'Erro ao salvar');
          if (data.html) {
            tr.outerHTML = data.html;
            bindDeleteButtons();
          } else {
            tr.remove();
          }
        } catch (err) {
          console.error('[NM-net] Erro:', err.message);
          setIcon(saveInline, 'ti-alert-circle', false);
          setTimeout(() => setIcon(saveInline, 'ti-device-floppy', false), 3000);
        }
      });

      tr.querySelector('#nm-net-ip_network').addEventListener('keydown', e => {
        if (e.key === 'Enter') saveInline.click();
      });
    });
  }

  function bindDeleteButtons() {
    document.querySelectorAll('.nm-net-delete').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!confirm('{{ 'Excluir esta rede?'|trans({}, 'newmanagement') }}')) return;
        btn.disabled = true;
        try {
          const data = await nmPost({
            action       : 'delete_network',
            id           : btn.dataset.id,
            companies_id : companiesId,
          });
          if (!data.success) throw new Error(data.error || 'Erro');
          const row = document.getElementById('nm-net-row-' + btn.dataset.id);
          if (row) row.remove();
          if (!document.querySelector('#nm-net-rows tr')) {
            const emptyTr = document.createElement('tr');
            emptyTr.id = 'nm-net-empty';
            emptyTr.innerHTML = `<td colspan="7" class="text-center text-muted py-3"><i class="ti ti-wifi-off me-1"></i>Nenhuma rede cadastrada. Clique em + Adicionar para incluir.</td>`;
            document.getElementById('nm-net-rows').appendChild(emptyTr);
          }
        } catch (err) { btn.disabled = false; }
      });
    });
  }
  bindDeleteButtons();

  if (!document.getElementById('nm-spin-style')) {
    const s = document.createElement('style');
    s.id = 'nm-spin-style';
    s.textContent = '@keyframes nm-spin{to{transform:rotate(360deg)}}.nm-spin{animation:nm-spin .8s linear infinite}';
    document.head.appendChild(s);
  }

}());
</script>
