{#
  templates/ipbx/tab_extensions.html.twig
  Aba de Ramais — padrão GLPI 11: linha inline criada pelo botão '+ Adicionar'.

  Variáveis recebidas de IpbxExtension::showForIpbx():
    rows         — array de registros existentes
    ipbx_id      — int
    companies_id — int
    can_write    — bool
    can_delete   — bool
    csrf         — string
    action_url   — string
#}
<div class="nm-ext-tab"
     data-action-url="{{ action_url|e('html_attr') }}"
     data-ipbx-id="{{ ipbx_id }}"
     data-companies-id="{{ companies_id }}">

  <table class="tab_cadre_fixe" id="nm-ext-list">
    <thead>
      <tr class="tab_bg_2">
        <th>{{ 'Ramal'|trans({}, 'newmanagement') }} <span class="text-danger">*</span></th>
        <th>{{ 'Usuário'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'IP Dispositivo'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Departamento'|trans({}, 'newmanagement') }}</th>
        <th>{{ 'Grava?'|trans({}, 'newmanagement') }}</th>
        <th style="width:120px;">
          {% if can_write %}
          <button type="button" id="nm-ext-add-btn" class="btn btn-sm btn-primary">
            <i class="ti ti-plus"></i> {{ '+ Adicionar'|trans({}, 'newmanagement') }}
          </button>
          {% endif %}
        </th>
      </tr>
    </thead>
    <tbody id="nm-ext-rows">
      {% for row in rows %}
      <tr id="nm-ext-row-{{ row.id }}">
        <td>{{ row.number|e }}</td>
        <td>{{ row.user_name|default('-')|e }}</td>
        <td>{{ row.device_ip|default('-')|e }}</td>
        <td>{{ row.department|default('-')|e }}</td>
        <td>
          {% if row.records_calls %}
            <span class="badge bg-success">{{ 'Sim'|trans({}, 'newmanagement') }}</span>
          {% else %}
            <span class="badge bg-secondary">{{ 'Não'|trans({}, 'newmanagement') }}</span>
          {% endif %}
        </td>
        <td>
          {% if can_delete %}
          <button type="button" class="btn btn-sm btn-danger nm-ext-delete" data-id="{{ row.id }}">
            <i class="ti ti-trash"></i>
          </button>
          {% endif %}
        </td>
      </tr>
      {% else %}
      <tr id="nm-ext-empty">
        <td colspan="6" class="text-center text-muted py-3">
          <i class="ti ti-phone-off me-1"></i>
          {{ 'Nenhum ramal cadastrado. Clique em + Adicionar para incluir.'|trans({}, 'newmanagement') }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

</div>

<script>
(function () {
  'use strict';

  const tab = document.querySelector('.nm-ext-tab');
  if (!tab) return;

  const actionUrl   = tab.dataset.actionUrl;
  const ipbxId      = tab.dataset.ipbxId;
  const companiesId = tab.dataset.companiesId;

  /* ── CSRF ──────────────────────────────────────────── */
  function nmCsrf() {
    const meta = document.querySelector('meta[property="glpi:csrf_token"]');
    if (meta && meta.getAttribute('content')) return meta.getAttribute('content');
    const h = document.querySelector('input[name="_glpi_csrf_token"]');
    return h ? h.value : '';
  }

  /* ── POST via fetch ────────────────────────────────── */
  async function nmPost(body) {
    const csrf = nmCsrf();
    const fd = new FormData();
    fd.append('_glpi_csrf_token', csrf);
    for (const [k, v] of Object.entries(body)) {
      if (k !== '_glpi_csrf_token') fd.append(k, v ?? '');
    }
    const r = await fetch(actionUrl, {
      method : 'POST',
      headers: { 'X-Glpi-Csrf-Token': csrf },
      body   : fd,
      signal : AbortSignal.timeout(10000),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const json = await r.json();
    if (json && json.csrf) {
      const meta = document.querySelector('meta[property="glpi:csrf_token"]');
      if (meta) meta.setAttribute('content', json.csrf);
    }
    return json;
  }

  function setIcon(btn, icon, spin) {
    const i = btn.querySelector('i');
    if (i) i.className = 'ti ' + icon + (spin ? ' nm-spin' : '');
    btn.disabled = spin;
  }

  /* ── Botão '+ Adicionar' — cria linha inline ───────── */
  const addBtn = document.getElementById('nm-ext-add-btn');
  if (addBtn) {
    addBtn.addEventListener('click', () => {
      const tbody = document.getElementById('nm-ext-rows');
      const empty = document.getElementById('nm-ext-empty');
      if (empty) empty.remove();

      const tr = document.createElement('tr');
      tr.className = 'nm-ext-new-row';
      tr.innerHTML = `
        <td><input type="text"     class="form-control form-control-sm" id="nm-ext-number"        placeholder="Ex: 1001" required></td>
        <td><input type="text"     class="form-control form-control-sm" id="nm-ext-user_name"     placeholder="Nome do usuário"></td>
        <td><input type="text"     class="form-control form-control-sm" id="nm-ext-device_ip"     placeholder="192.168.1.x"></td>
        <td><input type="text"     class="form-control form-control-sm" id="nm-ext-department"    placeholder="Ex: Comercial"></td>
        <td>
          <select class="form-select form-select-sm" id="nm-ext-records_calls">
            <option value="0">Não</option>
            <option value="1">Sim</option>
          </select>
        </td>
        <td class="d-flex gap-1">
          <button type="button" class="btn btn-sm btn-success" id="nm-ext-save-inline">
            <i class="ti ti-device-floppy"></i>
          </button>
          <button type="button" class="btn btn-sm btn-secondary" id="nm-ext-cancel-inline">
            <i class="ti ti-x"></i>
          </button>
        </td>`;
      tbody.appendChild(tr);
      tr.querySelector('#nm-ext-number').focus();

      /* Cancelar: remove a linha nova */
      tr.querySelector('#nm-ext-cancel-inline').addEventListener('click', () => {
        tr.remove();
        if (!document.querySelector('#nm-ext-rows tr:not(.nm-ext-new-row)')) {
          const emptyTr = document.createElement('tr');
          emptyTr.id = 'nm-ext-empty';
          emptyTr.innerHTML = `<td colspan="6" class="text-center text-muted py-3"><i class="ti ti-phone-off me-1"></i>Nenhum ramal cadastrado. Clique em + Adicionar para incluir.</td>`;
          document.getElementById('nm-ext-rows').appendChild(emptyTr);
        }
      });

      /* Salvar: envia AJAX e substitui linha de edição por linha de leitura */
      const saveInline = tr.querySelector('#nm-ext-save-inline');
      saveInline.addEventListener('click', async () => {
        const number = tr.querySelector('#nm-ext-number').value.trim();
        if (!number) { tr.querySelector('#nm-ext-number').focus(); return; }

        setIcon(saveInline, 'ti-loader-2', true);
        try {
          const data = await nmPost({
            action        : 'add_extension',
            ipbx_id       : ipbxId,
            companies_id  : companiesId,
            number        : number,
            user_name     : tr.querySelector('#nm-ext-user_name').value,
            device_ip     : tr.querySelector('#nm-ext-device_ip').value,
            department    : tr.querySelector('#nm-ext-department').value,
            records_calls : tr.querySelector('#nm-ext-records_calls').value,
          });

          if (!data.success) throw new Error(data.error || 'Erro ao salvar');

          /* Substitui linha de edição pelo HTML retornado pelo servidor */
          if (data.html) {
            tr.outerHTML = data.html;
            bindDeleteButtons();
          } else {
            tr.remove();
          }
        } catch (err) {
          console.error('[NM-ext] Erro:', err.message);
          setIcon(saveInline, 'ti-alert-circle', false);
          setTimeout(() => setIcon(saveInline, 'ti-device-floppy', false), 3000);
        }
      });

      /* Salvar ao pressionar Enter no campo ramal */
      tr.querySelector('#nm-ext-number').addEventListener('keydown', e => {
        if (e.key === 'Enter') saveInline.click();
      });
    });
  }

  /* ── Botões de exclusão (existentes + futuros) ──────── */
  function bindDeleteButtons() {
    document.querySelectorAll('.nm-ext-delete').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        if (!confirm('{{ 'Excluir este ramal?'|trans({}, 'newmanagement') }}')) return;
        btn.disabled = true;
        try {
          const data = await nmPost({
            action       : 'delete_extension',
            id           : btn.dataset.id,
            companies_id : companiesId,
          });
          if (!data.success) throw new Error(data.error || 'Erro');
          const row = document.getElementById('nm-ext-row-' + btn.dataset.id);
          if (row) row.remove();
          if (!document.querySelector('#nm-ext-rows tr')) {
            const emptyTr = document.createElement('tr');
            emptyTr.id = 'nm-ext-empty';
            emptyTr.innerHTML = `<td colspan="6" class="text-center text-muted py-3"><i class="ti ti-phone-off me-1"></i>Nenhum ramal cadastrado. Clique em + Adicionar para incluir.</td>`;
            document.getElementById('nm-ext-rows').appendChild(emptyTr);
          }
        } catch (err) { btn.disabled = false; }
      });
    });
  }
  bindDeleteButtons();

  /* ── Spinner CSS ────────────────────────────────────── */
  if (!document.getElementById('nm-spin-style')) {
    const s = document.createElement('style');
    s.id = 'nm-spin-style';
    s.textContent = '@keyframes nm-spin{to{transform:rotate(360deg)}}.nm-spin{animation:nm-spin .8s linear infinite}';
    document.head.appendChild(s);
  }

}());
</script>
