{#
  Newmanagement - Formulário de IPBX On-Premise
#}
{% extends 'layout/page.html.twig' %}

{% block content %}
<div class="container-fluid">

  <h2>
    {% if item.id %}
      {{ 'Editar IPBX'|__('newmanagement') }} — {{ item.name }}
    {% else %}
      {{ 'Novo IPBX'|__('newmanagement') }}
    {% endif %}
  </h2>

  <div class="card mt-3">
    <div class="card-body">
      <form method="POST" action="">
        <input type="hidden" name="id" value="{{ item.id|default('') }}">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token|e }}">

        <div class="row g-3">

          <div class="col-md-6">
            <label class="form-label" for="name">
              {{ 'Nome'|__('newmanagement') }} <span class="text-danger">*</span>
            </label>
            <input type="text" id="name" name="name" class="form-control"
                   value="{{ item.name|default('') }}" required>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="companies_id">{{ 'Empresa'|__('newmanagement') }}</label>
            <select id="companies_id" name="companies_id" class="form-select">
              <option value="">— {{ 'Selecione'|__('newmanagement') }} —</option>
              {% for company in companies %}
              <option value="{{ company.id }}"
                {% if item.companies_id == company.id %}selected{% endif %}>
                {{ company.name }}
              </option>
              {% endfor %}
            </select>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="ip_address">{{ 'Endereço IP'|__('newmanagement') }}</label>
            <input type="text" id="ip_address" name="ip_address" class="form-control"
                   value="{{ item.ip_address|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="asterisk_version">{{ 'Versão Asterisk'|__('newmanagement') }}</label>
            <input type="text" id="asterisk_version" name="asterisk_version" class="form-control"
                   value="{{ item.asterisk_version|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="sip_trunk">{{ 'SIP Trunk'|__('newmanagement') }}</label>
            <input type="text" id="sip_trunk" name="sip_trunk" class="form-control"
                   value="{{ item.sip_trunk|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="extensions_count">{{ 'Quantidade de Ramais'|__('newmanagement') }}</label>
            <input type="number" id="extensions_count" name="extensions_count" class="form-control"
                   value="{{ item.extensions_count|default(0) }}" min="0">
          </div>

          <div class="col-12">
            <label class="form-label" for="comment">{{ 'Observações'|__('newmanagement') }}</label>
            <textarea id="comment" name="comment" class="form-control" rows="3">{{ item.comment|default('') }}</textarea>
          </div>

        </div>

        <div class="mt-4 d-flex gap-2">
          <button type="submit" name="update" class="btn btn-primary">
            <i class="ti ti-device-floppy"></i>
            {{ 'Salvar'|__('newmanagement') }}
          </button>
          <a href="{{ path('GlpiPlugin\\Newmanagement\\Ipbx') }}" class="btn btn-secondary">
            {{ 'Cancelar'|__('newmanagement') }}
          </a>
        </div>

      </form>
    </div>
  </div>

</div>
{% endblock %}
