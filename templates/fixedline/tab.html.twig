{#
  templates/fixedline/tab.html.twig
  Aba de Linha Fixa dentro da ficha de Empresa.

  Variáveis recebidas de FixedLine::displayTabContentForCompany():
    f            — array com todos os campos da linha
    line_id      — int (0 = novo)
    ipbx_id      — int
    companies_id — int
    csrf         — string
    action_url   — string (URL do endpoint AJAX)
    form_action  — 'add_line' | 'update_line'
    can_write    — bool
    status_opts  — array {1: 'Ativo', 2: 'Cancelado'}
#}
<form id="nm-lines-form" autocomplete="off" onsubmit="return false;">

  <input type="hidden" name="_glpi_csrf_token" value="{{ csrf }}">
  <input type="hidden" name="action"           value="{{ form_action }}">
  <input type="hidden" name="id"               value="{{ line_id }}">
  <input type="hidden" name="ipbx_id"          value="{{ ipbx_id }}">
  <input type="hidden" name="companies_id"     value="{{ companies_id }}">

  <table class="tab_cadre_fixe">

    <tr class="tab_bg_1">
      <td>{{ 'Número Piloto'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="pilot_number" autocomplete="off"
               value="{{ f.pilot_number|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: 1131000000"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Quantidade de DDR'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="number" name="ddr_count" autocomplete="off"
               value="{{ f.ddr_count|e('html_attr') }}"
               class="form-control" min="0" placeholder="0"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Status'|trans({}, 'newmanagement') }}</td>
      <td>
        <select name="status" class="form-select"
                {{ not can_write ? 'readonly disabled' }}>
          {% for val, lbl in status_opts %}
            <option value="{{ val }}"
                    {{ f.status|default(1)|number_format == val ? 'selected' }}>
              {{ lbl }}
            </option>
          {% endfor %}
        </select>
      </td>
    </tr>

    <tr class="tab_bg_1">
      <td>{{ 'Operadora'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="operator" autocomplete="off"
               value="{{ f.operator|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: Vivo"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Quantidade de Canais'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="number" name="channels" autocomplete="off"
               value="{{ f.channels|e('html_attr') }}"
               class="form-control" min="0" placeholder="0"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'IP Proxy'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="proxy_ip" autocomplete="off"
               value="{{ f.proxy_ip|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: 200.x.x.x"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
    </tr>

    <tr class="tab_bg_1">
      <td>{{ 'Tipo'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="line_type" autocomplete="off"
               value="{{ f.line_type|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: SIP, E1"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'IP Tráfego Áudio'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="audio_ip" autocomplete="off"
               value="{{ f.audio_ip|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: 200.x.x.x"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Porta Proxy'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="proxy_port" autocomplete="off"
               value="{{ f.proxy_port|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: 5060"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
    </tr>

    <tr class="tab_bg_1">
      <td>{{ 'Data Portabilidade'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="date" name="portability_date" autocomplete="off"
               value="{{ f.portability_date|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Operadora Anterior'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="text" name="previous_operator" autocomplete="off"
               value="{{ f.previous_operator|e('html_attr') }}"
               class="form-control"
               placeholder="Ex: Claro"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td colspan="2"></td>
    </tr>

    <tr class="tab_bg_1">
      <td>{{ 'Data de Ativação'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="date" name="activation_date" autocomplete="off"
               value="{{ f.activation_date|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td>{{ 'Data de Vencimento'|trans({}, 'newmanagement') }}</td>
      <td>
        <input type="date" name="expiration_date" autocomplete="off"
               value="{{ f.expiration_date|e('html_attr') }}"
               class="form-control"
               {{ not can_write ? 'readonly disabled' }}>
      </td>
      <td colspan="2"></td>
    </tr>

    <tr class="tab_bg_1">
      <td>{{ 'Comentário'|trans({}, 'newmanagement') }}</td>
      <td colspan="5">
        <textarea name="comment" class="form-control" rows="2"
                  {{ not can_write ? 'readonly disabled' }}
        >{{ f.comment|e }}</textarea>
      </td>
    </tr>

  </table>

  {% if can_write %}
    <div style="text-align:right;padding:var(--space-4,1rem) 0">
      <button type="submit" form="nm-lines-form" class="btn btn-primary">
        <i class="ti ti-device-floppy"></i>
        {{ 'Salvar Linha'|trans({}, 'newmanagement') }}
      </button>
    </div>
  {% endif %}

</form>
