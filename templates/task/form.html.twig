{#
  Newmanagement - Formulário de Tarefa
#}
{% extends 'layout/page.html.twig' %}

{% block content %}
<div class="container-fluid">

  <h2>
    {% if item.id %}
      {{ 'Editar Tarefa'|__('newmanagement') }} — {{ item.name }}
    {% else %}
      {{ 'Nova Tarefa'|__('newmanagement') }}
    {% endif %}
  </h2>

  <div class="card mt-3">
    <div class="card-body">
      <form method="POST" action="">
        <input type="hidden" name="id" value="{{ item.id|default('') }}">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

        <div class="row g-3">

          <div class="col-md-6">
            <label class="form-label" for="name">
              {{ 'Nome'|__('newmanagement') }} <span class="text-danger">*</span>
            </label>
            <input type="text" id="name" name="name" class="form-control"
                   value="{{ item.name|default('') }}" required>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="companies_id">{{ 'Empresa'|__('newmanagement') }}</label>
            <select id="companies_id" name="companies_id" class="form-select">
              <option value="">— {{ 'Selecione'|__('newmanagement') }} —</option>
              {% for company in companies %}
              <option value="{{ company.id }}"
                {% if item.companies_id == company.id %}selected{% endif %}>
                {{ company.name }}
              </option>
              {% endfor %}
            </select>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="assigned_user_id">{{ 'Responsável'|__('newmanagement') }}</label>
            <select id="assigned_user_id" name="assigned_user_id" class="form-select">
              <option value="">— {{ 'Selecione'|__('newmanagement') }} —</option>
              {% for user in users %}
              <option value="{{ user.id }}"
                {% if item.assigned_user_id == user.id %}selected{% endif %}>
                {{ user.name }}
              </option>
              {% endfor %}
            </select>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="status">{{ 'Status'|__('newmanagement') }}</label>
            <select id="status" name="status" class="form-select">
              <option value="0" {% if item.status == 0 %}selected{% endif %}>
                {{ 'Aberta'|__('newmanagement') }}
              </option>
              <option value="1" {% if item.status == 1 %}selected{% endif %}>
                {{ 'Em andamento'|__('newmanagement') }}
              </option>
              <option value="2" {% if item.status == 2 %}selected{% endif %}>
                {{ 'Concluída'|__('newmanagement') }}
              </option>
            </select>
          </div>

          <div class="col-md-6">
            <label class="form-label" for="date_due">{{ 'Prazo'|__('newmanagement') }}</label>
            <input type="datetime-local" id="date_due" name="date_due" class="form-control"
                   value="{{ item.date_due|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="km_calculated">{{ 'KM Calculado'|__('newmanagement') }}</label>
            <input type="number" step="0.01" id="km_calculated" name="km_calculated" class="form-control"
                   value="{{ item.km_calculated|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="latitude">{{ 'Latitude'|__('newmanagement') }}</label>
            <input type="number" step="0.0000001" id="latitude" name="latitude" class="form-control"
                   value="{{ item.latitude|default('') }}">
          </div>

          <div class="col-md-6">
            <label class="form-label" for="longitude">{{ 'Longitude'|__('newmanagement') }}</label>
            <input type="number" step="0.0000001" id="longitude" name="longitude" class="form-control"
                   value="{{ item.longitude|default('') }}">
          </div>

          <div class="col-12">
            <label class="form-label" for="digital_signature">{{ 'Assinatura Digital'|__('newmanagement') }}</label>
            <textarea id="digital_signature" name="digital_signature" class="form-control" rows="2">{{ item.digital_signature|default('') }}</textarea>
          </div>

          <div class="col-12">
            <label class="form-label" for="comment">{{ 'Observações'|__('newmanagement') }}</label>
            <textarea id="comment" name="comment" class="form-control" rows="3">{{ item.comment|default('') }}</textarea>
          </div>

        </div>

        <div class="mt-4 d-flex gap-2">
          <button type="submit" name="update" class="btn btn-primary">
            <i class="ti ti-device-floppy"></i>
            {{ 'Salvar'|__('newmanagement') }}
          </button>
          <a href="{{ path('GlpiPlugin\\Newmanagement\\Task') }}" class="btn btn-secondary">
            {{ 'Cancelar'|__('newmanagement') }}
          </a>
        </div>

      </form>
    </div>
  </div>

</div>
{% endblock %}
