{#
  Newmanagement - Lista de Tarefas
#}
{% extends 'layout/page.html.twig' %}

{% block content %}
<div class="container-fluid">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>{{ 'Tarefas'|__('newmanagement') }}</h2>
    <a href="{{ path('GlpiPlugin\\Newmanagement\\Task') }}?action=add"
       class="btn btn-primary">
      <i class="ti ti-plus"></i>
      {{ 'Adicionar Tarefa'|__('newmanagement') }}
    </a>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>{{ 'ID'|__('newmanagement') }}</th>
            <th>{{ 'Nome'|__('newmanagement') }}</th>
            <th>{{ 'Empresa'|__('newmanagement') }}</th>
            <th>{{ 'Responsável'|__('newmanagement') }}</th>
            <th>{{ 'Status'|__('newmanagement') }}</th>
            <th>{{ 'Prazo'|__('newmanagement') }}</th>
            <th>{{ 'KM'|__('newmanagement') }}</th>
          </tr>
        </thead>
        <tbody>
          {% for item in items %}
          <tr>
            <td>{{ item.id }}</td>
            <td>
              <a href="{{ path('GlpiPlugin\\Newmanagement\\Task') }}?id={{ item.id }}">
                {{ item.name }}
              </a>
            </td>
            <td>{{ item.company_name ?? '-' }}</td>
            <td>{{ item.assigned_user_name ?? '-' }}</td>
            <td>
              {% if item.status == 0 %}
                <span class="badge bg-secondary">{{ 'Aberta'|__('newmanagement') }}</span>
              {% elseif item.status == 1 %}
                <span class="badge bg-primary">{{ 'Em andamento'|__('newmanagement') }}</span>
              {% else %}
                <span class="badge bg-success">{{ 'Concluída'|__('newmanagement') }}</span>
              {% endif %}
            </td>
            <td>
              {% if item.date_due %}
                {{ item.date_due|date('d/m/Y') }}
              {% else %}
                -
              {% endif %}
            </td>
            <td>{{ item.km_calculated ?? '-' }}</td>
          </tr>
          {% else %}
          <tr>
            <td colspan="7" class="text-center text-muted py-4">
              {{ 'Nenhuma tarefa cadastrada.'|__('newmanagement') }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

</div>
{% endblock %}
